<UserControl x:Class="SilentInstall.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="680">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"             Value="160"/>
            <Setter Property="Margin"            Value="0,0,12,0"/>
        </Style>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{DynamicResource TextBrushDarker}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="172,3,0,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height"  Value="34"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="Padding"                  Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height"  Value="30"/>
            <Setter Property="Width"   Value="34"/>
            <Setter Property="Margin"  Value="6,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="20">

        <!-- ═══ STEAM ═══ -->
        <TextBlock Style="{StaticResource SectionHeader}" Text="🎮  STEAM"/>

        <!-- Info box -->
        <Border Background="#1266BB2A" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Foreground="#66BB2A" FontWeight="SemiBold" FontSize="11" Text="How it works"/>
                <TextBlock Foreground="{DynamicResource TextBrushDarker}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="Silent Install creates an appmanifest file in your steamapps folder. Steam detects it on startup and begins downloading automatically — no popup, no interaction required."/>
            </StackPanel>
        </Border>

        <!-- Library dropdown -->
        <StackPanel Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Steam library"/>
                <ComboBox Width="470"
                          ItemsSource="{Binding DetectedSteamLibraries}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Path"
                          SelectedValue="{Binding SelectedLibraryPath}"
                          ToolTip="Select the Steam library where games will be installed"/>
            </StackPanel>
            <TextBlock Style="{StaticResource HelpText}"
                       Text="All your Steam libraries are detected automatically from Steam's configuration."/>
            <TextBlock Style="{StaticResource HelpText}" Margin="172,2,0,0"
                       Text="If your target library is missing, add it first in Steam → Settings → Storage."/>
        </StackPanel>

        <!-- Custom path checkbox + field -->
        <StackPanel Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Style="{StaticResource FieldLabel}" Text=""/>
                <CheckBox Content="Use a custom path instead"
                          IsChecked="{Binding UseCustomPath}"
                          Foreground="{DynamicResource TextBrush}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Shown only when checkbox is checked -->
            <StackPanel Visibility="{Binding UseCustomPath, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Custom steamapps path"/>
                    <TextBox Width="400"
                             Text="{Binding CustomPath, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Full path to your steamapps folder"/>
                    <Button Content="📂" Click="BrowseCustomPath_Click" ToolTip="Browse"/>
                </StackPanel>
                <TextBlock Style="{StaticResource HelpText}"
                           Foreground="{DynamicResource TextBrushDarker}" FontSize="11"
                           Text="Example: E:\SteamLibrary\steamapps"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
